        <property name="styleSheet">
         <string notr="true">QLineEdit {
  background-color: rgba(224, 224, 224, 0.7);  /* Light gray with 70% opacity */
    border: 1px solid rgba(160, 160, 160, 0.5); /* Semi-transparent border */
    border-radius: 5px;

      /* Slightly rounded corners */

    /* Text Formatting */
    color: white;           /* Black text color */
    font-family: &quot;Segoe UI&quot;, &quot;Arial, sans-serif&quot;;       /* Use a clear font, adjust as desired */
    font-size: 28px;          /* Increased font size for better visibility */
    text-align: right;         /* Right-align the text, as in a calculator */
    padding-right: 15px;      /* Added padding */

    /* Size and Spacing */
    min-height: 80px;         /* Increased height */
    /* No margin here, margins are generally handled by layouts */
    height: 50px;

    /* Focus State (Optional) */
    /* &amp;:focus {
        border: 2px solid rgba(76, 175, 80, 0.7);
        box-shadow: 0 0 5px rgba(76, 175, 80, 0.7);
    }
    */

    /* Read-only State */
    readonly {
        background-color: rgba(224, 224, 224, 0.7);
        border: 1px solid rgba(160, 160, 160, 0.5);
        color: #000000;
    }
    selection-background-color: #b0d4ff;
    selection-color: #000000;
}
</string>
