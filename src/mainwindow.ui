        <item>
         <widget class="QPushButton" name="pushButton_16">
          <property name="styleSheet">
           <string notr="true">/* Base button style that will apply to all buttons */
QPushButton {
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 5px;
    color: white;
    padding: 8px;
    font-size: 16px;
    min-width: 40px;
    min-height: 40px;
}

/* Style for larger buttons (like AC, 0, etc.) */
QPushButton[largeButton=&quot;true&quot;] {
    padding: 12px;
    font-size: 18px;
    min-width: 60px;
    min-height: 60px;
}

/* Style for smaller buttons */
QPushButton[smallButton=&quot;true&quot;] {
    padding: 6px;
    font-size: 14px;
    min-width: 30px;
    min-height: 30px;
}

/* Number buttons specific style */
QPushButton[numberButton=&quot;true&quot;] {
    background-color: rgba(255, 255, 255, 0.15);
    font-weight: bold;
}

/* Operation buttons specific style */
QPushButton[operationButton=&quot;true&quot;] {
    background-color: rgba(74, 144, 226, 0.3);
}

/* Hover effects for all buttons */
QPushButton:hover {
    background-color: rgba(255, 255, 255, 0.2);
}

/* Pressed effects for all buttons */
QPushButton:pressed {
    background-color: rgba(255, 255, 255, 0.3);
}</string>
          </property>
          <property name="text">
           <string>/</string>
          </property>
         </widget>
        </item>
